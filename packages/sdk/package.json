{
  "name": "bot-sdk",
  "version": "1.0.0",
  "description": "Bot SDK - White-label React Native/Expo components and business logic",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./screens": {
      "types": "./src/screens/index.ts",
      "default": "./src/screens/index.ts"
    },
    "./provider": {
      "types": "./src/provider/index.ts",
      "default": "./src/provider/index.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "default": "./src/hooks/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atomicrobot/bot-sdk.git"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "expo": ">=50.0.0",
    "expo-router": ">=3.0.0",
    "@react-native-async-storage/async-storage": ">=1.0.0",
    "expo-haptics": ">=12.0.0",
    "expo-web-browser": ">=12.0.0",
    "expo-symbols": ">=0.1.0",
    "@expo/vector-icons": ">=14.0.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-safe-area-context": ">=4.0.0",
    "@react-navigation/native": ">=6.0.0",
    "@react-navigation/bottom-tabs": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "expo-audio": {
      "optional": true
    },
    "expo-video": {
      "optional": true
    },
    "react-native-webview": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-native-async-storage/async-storage": "^1.23.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native": "^6.1.0",
    "@types/react": "^18.2.0",
    "expo": "~51.0.0",
    "expo-haptics": "~13.0.0",
    "expo-router": "~3.5.0",
    "expo-symbols": "~0.1.0",
    "expo-web-browser": "~13.0.0",
    "react": "^18.2.0",
    "react-native": "^0.74.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "^4.10.0",
    "typescript": "~5.3.0"
  },
  "keywords": [
    "react-native",
    "expo",
    "white-label",
    "sdk"
  ],
  "license": "MIT"
}
